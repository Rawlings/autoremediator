{
  "name": "autoremediator-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Autoremediator monorepo (core package + docs app)",
  "keywords": [
    "security",
    "cve",
    "dependency-security",
    "remediation",
    "npm",
    "pnpm",
    "yarn",
    "mcp",
    "openapi",
    "agentic"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Rawlings/autoremediator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rawlings/autoremediator.git"
  },
  "bugs": {
    "url": "https://github.com/Rawlings/autoremediator/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/Rawlings"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --dir packages/core build",
    "build:vsix": "pnpm --dir packages/vscode-extension build:vsix",
    "dev": "pnpm --dir packages/core dev",
    "extension:package": "pnpm --dir packages/vscode-extension build:vsix",
    "typecheck": "pnpm --dir packages/core typecheck",
    "test": "pnpm --dir packages/core test",
    "test:watch": "pnpm --dir packages/core test:watch",
    "docs:dev": "pnpm --dir packages/docs dev",
    "docs:build": "pnpm --dir packages/docs build",
    "docs:preview": "pnpm --dir packages/docs preview"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.18.3"
}
