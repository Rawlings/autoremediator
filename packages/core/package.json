{
  "name": "autoremediator",
  "private": false,
  "version": "0.13.0",
  "description": "Agentic CVE remediation platform for Node.js. Correlates threat intelligence, applies policy-governed fixes, and delivers auditable remediation outcomes across CI/CD pipelines, agent workflows, and service portfolios.",
  "keywords": [
    "security-remediation",
    "vulnerability-remediation",
    "cve",
    "remediation",
    "security",
    "dependency-security",
    "software-supply-chain",
    "supply-chain",
    "npm-security",
    "node-security",
    "sca",
    "devsecops",
    "npm-audit",
    "yarn-audit",
    "sarif",
    "scanner",
    "osv",
    "ghsa",
    "github-advisory",
    "nvd",
    "agentic",
    "ai",
    "llm",
    "mcp",
    "mcp-server",
    "mythos",
    "claude-mythos",
    "claude-mcp",
    "openapi",
    "agent-tooling",
    "npm",
    "yarn",
    "pnpm"
  ],
  "author": "Rawlings",
  "license": "MIT",
  "homepage": "https://github.com/Rawlings/autoremediator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rawlings/autoremediator.git"
  },
  "bugs": {
    "url": "https://github.com/Rawlings/autoremediator/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/Rawlings"
  },
  "type": "module",
  "bin": {
    "autoremediator": "./dist/cli.js",
    "autoremediator-mcp": "./dist/mcp/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "llms.txt"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js"
    },
    "./openapi": {
      "import": "./dist/openapi/server.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.168",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "semver": "^7.7.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}