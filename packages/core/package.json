{
  "name": "autoremediator",
  "private": false,
  "version": "0.7.0",
  "description": "Risk-aware, agentic CVE remediation for Node.js using OSV, CISA KEV, and FIRST EPSS intelligence with policy and evidence controls.",
  "keywords": [
    "security-remediation",
    "dependency-security",
    "vulnerability-remediation",
    "software-supply-chain",
    "npm-security",
    "node-security",
    "cve",
    "vulnerability",
    "security",
    "dependency",
    "remediation",
    "auto-remediation",
    "npm-audit",
    "yarn-audit",
    "sarif",
    "supply-chain",
    "agentic",
    "ai",
    "llm",
    "mcp",
    "openapi",
    "osv",
    "ghsa",
    "github-advisory",
    "nvd",
    "pnpm",
    "npm",
    "yarn",
    "scanner",
    "dependency-upgrade",
    "sarif-security",
    "mcp-server"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/Rawlings/autoremediator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rawlings/autoremediator.git"
  },
  "bugs": {
    "url": "https://github.com/Rawlings/autoremediator/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/Rawlings"
  },
  "type": "module",
  "bin": {
    "autoremediator": "./dist/cli.js",
    "autoremediator-mcp": "./dist/mcp/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "llms.txt"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js"
    },
    "./openapi": {
      "import": "./dist/openapi/server.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^4.3.19",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "execa": "^9.6.1",
    "semver": "^7.7.4",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "@types/node": "^24.12.0",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}