{
  "name": "autoremediator",
  "private": false,
  "version": "0.1.1",
  "description": "Automated CVE remediation for Node.js dependencies with CLI, SDK, MCP, and scanner-to-fix workflows.",
  "keywords": [
    "security-remediation",
    "dependency-security",
    "vulnerability-remediation",
    "software-supply-chain",
    "npm-security",
    "node-security",
    "cve",
    "vulnerability",
    "security",
    "dependency",
    "remediation",
    "auto-remediation",
    "npm-audit",
    "yarn-audit",
    "sarif",
    "supply-chain",
    "agentic",
    "ai",
    "llm",
    "mcp",
    "openapi",
    "osv",
    "ghsa",
    "github-advisory",
    "nvd",
    "pnpm",
    "npm",
    "yarn",
    "scanner",
    "dependency-upgrade",
    "sarif-security",
    "mcp-server"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/Rawlings/autoremediator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rawlings/autoremediator.git"
  },
  "bugs": {
    "url": "https://github.com/Rawlings/autoremediator/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/Rawlings"
  },
  "type": "module",
  "bin": {
    "autoremediator": "./dist/cli.js",
    "autoremediator-mcp": "./dist/mcp/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "llms.txt"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js"
    },
    "./openapi": {
      "import": "./dist/openapi/server.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ai": "^4.3.16",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "semver": "^7.7.1",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.22",
    "@types/node": "^22.13.14",
    "@types/semver": "^7.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}