{
  "name": "@autoremediator/github-app",
  "private": true,
  "version": "0.1.0",
  "description": "GitHub App MVP foundation for autoremediator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
