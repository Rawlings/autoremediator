# Environment variables for autoremediator

# LLM provider: "openai" | "anthropic" | "local"
AUTOREMEDIATOR_LLM_PROVIDER=openai

# Local mode requires no API keys and runs deterministic remediation logic.
# AUTOREMEDIATOR_LLM_PROVIDER=local

# Model to use (defaults to provider's recommended model if unset)
# AUTOREMEDIATOR_MODEL=gpt-4o

# OpenAI API key (required if AUTOREMEDIATOR_LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic API key (required if AUTOREMEDIATOR_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: NVD API key for higher rate limits (5 -> 50 req/30s)
# AUTOREMEDIATOR_NVD_API_KEY=...

# Optional: GitHub token for higher advisory API rate limits
# GITHUB_TOKEN=...
