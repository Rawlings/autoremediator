# Environment variables for autoremediator

# LLM provider: "remote" | "local" (default: "remote")
# Use "local" for fully deterministic remediation with no API keys required.
AUTOREMEDIATOR_LLM_PROVIDER=remote

# Remote provider API key (required when AUTOREMEDIATOR_LLM_PROVIDER=remote)
# AUTOREMEDIATOR_REMOTE_API_KEY=

# Remote client adapter module (required when AUTOREMEDIATOR_LLM_PROVIDER=remote)
# Must be an installed package that exports a createRemoteClient factory.
# AUTOREMEDIATOR_REMOTE_CLIENT_MODULE=my-remote-adapter
# AUTOREMEDIATOR_REMOTE_CLIENT_FACTORY=createRemoteClient

# Model overrides (defaults to provider's built-in model names if unset)
# AUTOREMEDIATOR_MODEL=                  # overrides all providers
# AUTOREMEDIATOR_MODEL_REMOTE=           # overrides remote provider only
# AUTOREMEDIATOR_MODEL_LOCAL=            # overrides local provider only
# AUTOREMEDIATOR_MODEL_REMOTE_LARGE=     # used for large-context dynamic routing (remote only)

# Optional: NVD API key for higher rate limits (5 -> 50 req/30s)
# AUTOREMEDIATOR_NVD_API_KEY=

# Optional: GitHub token for higher advisory API rate limits
# GITHUB_TOKEN=

# Optional: override default intelligence source endpoints
# AUTOREMEDIATOR_GITLAB_ADVISORY_API=https://advisories.gitlab.com/api/v1/advisories
# AUTOREMEDIATOR_CERTCC_SEARCH_URL=https://www.kb.cert.org/vuls/search
# AUTOREMEDIATOR_EPSS_API=https://api.first.org/data/v1/epss
# AUTOREMEDIATOR_CVE_SERVICES_API=https://cveawg.mitre.org/api/cve
# AUTOREMEDIATOR_DEPSDEV_API=https://api.deps.dev/v3
# AUTOREMEDIATOR_SCORECARD_API=https://api.securityscorecards.dev

# Optional: vendor or commercial advisory feeds (comma-separated URLs)
# AUTOREMEDIATOR_VENDOR_ADVISORY_FEEDS=
# AUTOREMEDIATOR_COMMERCIAL_FEEDS=
# AUTOREMEDIATOR_COMMERCIAL_FEED_TOKEN=

# =============================================================================
# GitHub App Server
# =============================================================================
# These variables configure the autoremediator GitHub App runtime.
# Credentials (section 1) are produced by the /setup registration flow.
# Everything else has a working default — only change what you need.

# --- 1. Credentials (required after /setup registration) -------------------

# GitHub App ID, private key, and webhook secret are generated by GitHub
# during app registration. Navigate to http://localhost:3001/setup and click
# "Create GitHub App on GitHub" to register — GitHub redirects back with
# these three values ready to copy.
AUTOREMEDIATOR_GITHUB_APP_ID=
AUTOREMEDIATOR_GITHUB_APP_PRIVATE_KEY=
AUTOREMEDIATOR_GITHUB_APP_WEBHOOK_SECRET=

# --- 2. Server -------------------------------------------------------------

# Public URL of this server. Required for /setup to build the app manifest
# so GitHub knows where to deliver webhooks after registration.
# Example: https://autoremediator.example.com
AUTOREMEDIATOR_GITHUB_APP_BASE_URL=

# HTTP listen port (default: 3001)
# AUTOREMEDIATOR_GITHUB_APP_PORT=3001

# Persistent state directory. When set, webhook deduplication and job queue
# state survive process restarts. Leave unset for ephemeral/stateless deploys.
# AUTOREMEDIATOR_GITHUB_APP_DATA_DIR=.autoremediator/github-app

# Enable the one-click /setup registration routes (default: true).
# Set to false once the app is registered and credentials are in place.
# AUTOREMEDIATOR_GITHUB_APP_ENABLE_SETUP_ROUTES=true

# Optional secret to gate access to the /setup registration endpoint.
# Recommended when BASE_URL is publicly reachable before registration.
# AUTOREMEDIATOR_GITHUB_APP_SETUP_SECRET=

# GitHub Enterprise Server base URLs. Leave unset for github.com.
# AUTOREMEDIATOR_GITHUB_APP_GITHUB_URL=https://github.example.com
# AUTOREMEDIATOR_GITHUB_APP_GITHUB_API_URL=https://github.example.com/api/v3

# --- 3. Remediation --------------------------------------------------------

# Enable the built-in remediation handler for check_suite and
# workflow_dispatch events (default: false — safe for initial setup).
# Per-repository behavior (dry-run, severity filter, PR settings) is
# configured in .github/autoremediator.yml in each target repository.
# AUTOREMEDIATOR_GITHUB_APP_ENABLE_DEFAULT_REMEDIATION=false

# Maximum time in ms to wait for a remediation callback to complete.
# Increase for large repositories or slow test suites (no default = no cap).
# AUTOREMEDIATOR_GITHUB_APP_TRIGGER_TIMEOUT_MS=300000

# --- 4. Hardening ----------------------------------------------------------

# Require application/json Content-Type on all webhook requests (default: true)
# AUTOREMEDIATOR_GITHUB_APP_REQUIRE_JSON_CONTENT_TYPE=true

# Require x-github-delivery header on all webhook requests (default: false)
# AUTOREMEDIATOR_GITHUB_APP_REQUIRE_DELIVERY_ID=false

# Maximum accepted webhook body size in bytes (default: 262144 = 256 KB)
# AUTOREMEDIATOR_GITHUB_APP_MAX_WEBHOOK_BODY_BYTES=262144

# Comma-separated allowlist of accepted webhook event names.
# When unset, all events that pass signature validation are accepted.
# AUTOREMEDIATOR_GITHUB_APP_ALLOWED_EVENTS=check_suite,workflow_dispatch,installation,installation_repositories

# Emit one JSON line per processed webhook event (default: false)
# AUTOREMEDIATOR_GITHUB_APP_LOG_EVENT_TRACES=false

# --- 5. Job queue ----------------------------------------------------------

# Queue-backed async execution decouples webhook intake from remediation
# runtime. Enabled by default so the server always returns promptly to GitHub.
# AUTOREMEDIATOR_GITHUB_APP_ENABLE_JOB_QUEUE=true

# How often the queue worker polls for new jobs in ms (default: 2000)
# AUTOREMEDIATOR_GITHUB_APP_QUEUE_POLL_INTERVAL_MS=2000

# Delay before retrying a failed job in ms (default: 15000)
# AUTOREMEDIATOR_GITHUB_APP_QUEUE_RETRY_DELAY_MS=15000

# Maximum attempts per job before it is marked permanently failed (default: 3)
# AUTOREMEDIATOR_GITHUB_APP_QUEUE_MAX_ATTEMPTS=3

# Number of jobs processed concurrently (default: 1).
# Increase only after validating that your runner has enough capacity
# to handle parallel install/test cycles.
# AUTOREMEDIATOR_GITHUB_APP_WORKER_CONCURRENCY=1

# --- 6. Scheduler ----------------------------------------------------------

# Periodic scheduler that enqueues workflow_dispatch jobs on an interval.
# Useful when you want scheduled scans without GitHub Actions (default: false).
# AUTOREMEDIATOR_GITHUB_APP_ENABLE_SCHEDULER=false

# Scheduler interval in ms (default: 3600000 = 1 hour)
# AUTOREMEDIATOR_GITHUB_APP_SCHEDULE_INTERVAL_MS=3600000

# --- 7. Status publishing --------------------------------------------------

# Publish GitHub check run results for queued and completed remediation jobs.
# Requires Contents and Checks write permissions on the app (default: false).
# AUTOREMEDIATOR_GITHUB_APP_ENABLE_STATUS_PUBLISHING=false

# Name shown on the GitHub check run (default: autoremediator/remediation)
# AUTOREMEDIATOR_GITHUB_APP_STATUS_CHECK_NAME=autoremediator/remediation
